# TruckDash Supabase (copy to .env.local and fill in from Project Settings → API)
# Lovable Cloud also injects VITE_SUPABASE_PUBLISHABLE_KEY — either key name works.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Default truck slug → menu-data/{id}/menu.json (Cluckin Chaos)
VITE_DEFAULT_TRUCK_ID=cluckin-chaos
