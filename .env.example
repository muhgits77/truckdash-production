# ═══════════════════════════════════════════════════════════════════════════
# TruckDash · Supabase (copy to .env and fill in)
#
#   cp .env.example .env
#   # paste keys from Supabase → Project Settings → API
#   npm run setup
#   npm run dev
#
# Docs: docs/CONNECT.md
# ═══════════════════════════════════════════════════════════════════════════

# Project URL  (Settings → API → Project URL)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Public anon key  (Settings → API → anon public)
# Also accepts the newer publishable key as VITE_SUPABASE_PUBLISHABLE_KEY
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Optional alias for the public key:
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Your truck slug → stored as menu-data/{id}/menu.json
# Use lowercase letters, numbers, hyphens (e.g. bluegrass-kitchen)
VITE_DEFAULT_TRUCK_ID=my-food-truck

# ── Demo Mode (public showcase on your main website) ─────────────────────────
# When true: top demo banner, locked high-res export / publish / full map edit,
# and “Contact for Sales” CTAs (open bluegrassdigitalforge.com/contact form).
# Restart `npm run dev` after changing.
NEXT_PUBLIC_DEMO_MODE=false
# Optional Vite-native alias (same effect):
# VITE_DEMO_MODE=false

# ── Server-only (NEVER use VITE_ — never put this in the browser) ───────────
# Settings → API → service_role (secret)
# Required for: npm run setup  +  reliable Publish on Vercel
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_here

# Optional: let npm run setup apply SQL policies automatically
# Settings → Database → Connection string (URI, session or transaction pooler)
# DATABASE_URL=postgresql://postgres.YOUR_REF:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres
