# ── Public (safe for VITE_ / browser / Vercel) ───────────────────────────────
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_jwt_here
# Optional alias (either works):
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

VITE_DEFAULT_TRUCK_ID=cluckin-chaos

# ── Server-only (NO VITE_ prefix — never expose to the browser) ──────────────
# Required for Publish until you run supabase/storage_buckets.sql (anon RLS).
# Add the same key in Vercel → Project → Settings → Environment Variables
# for Production + Preview (not "Vite" / public).
SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_jwt_here

# Optional: auto-apply storage_buckets.sql from scripts/setup-storage.mts
# DATABASE_URL=postgresql://postgres.[ref]:[db-password]@aws-0-....pooler.supabase.com:6543/postgres
